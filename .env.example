# PostgreSQL (Render provides DATABASE_URL when you link the Postgres database)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE_NAME

# Used to encrypt JWT tokens — generate a long random string for production
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Public site URL — no trailing slash (e.g. https://burlington-motors.onrender.com or your custom domain)
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Secret used to authenticate cron jobs
CRON_SECRET=YOUR_CRON_SECRET_HERE

# Used to validate draft preview requests
PREVIEW_SECRET=YOUR_PREVIEW_SECRET_HERE

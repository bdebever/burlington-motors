# Local Postgres via `docker compose up -d` (see docker-compose.yml)
# Production: Render sets DATABASE_URL automatically when the DB is linked.
DATABASE_URL=postgresql://postgres:devpass@127.0.0.1:5433/burlington

# Long random strings in production (32+ chars recommended)
PAYLOAD_SECRET=dev-payload-secret-minimum-32-characters-long
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
CRON_SECRET=dev-cron-secret-minimum-32-characters-long
PREVIEW_SECRET=dev-preview-secret-minimum-32-characters-long
